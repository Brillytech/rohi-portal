---
layout: layouts/base.njk
---

<section class="py-5 post-page">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-9">
        <article class="post-wrapper">

          {% if title %}
            <div class="mb-3">
              <a href="/news/" class="text-decoration-none small text-muted">
                ← Back to News
              </a>
            </div>

            <h1 class="fw-bold mb-3">{{ title }}</h1>
          {% endif %}

          {% if date %}
            <p class="post-meta text-muted mb-4">
              {{ date | date("MMMM dd, yyyy") }}
            </p>
          {% endif %}

          {% if image %}
            <div class="mb-4">
              <img src="{{ image }}" alt="{{ title }}" class="img-fluid rounded shadow-sm post-hero-img">
            </div>
          {% endif %}

          <div class="post-content">
            {{ content | safe }}
          </div>

        </article>
      </div>
    </div>
  </div>
</section>