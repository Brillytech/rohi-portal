---
layout: layouts/base.njk
---

<section class="py-5">
  <div class="container">
    <h1 class="fw-bold mb-2">{{ title }}</h1>
    <small class="text-muted">{{ page.date | date("MMMM dd, yyyy") }}</small>

    {% if image %}
      <img src="{{ image }}" class="img-fluid rounded shadow my-4" alt="{{ title }}">
    {% endif %}

    <div class="mt-3">
      {{ content | safe }}
    </div>
  </div>
</section>