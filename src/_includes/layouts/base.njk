<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="{{ description or 'Rohi Group of Schools – Excellence in learning and character.' }}">
  <meta name="keywords" content="Rohi Schools, Education, Ogun, Learning, Students, Academics, Rohi, Rohi College">

  <title>{{ title or "Rohi Schools" }}</title>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />

  <!-- AOS Animation CSS -->
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
</head>

<body>
  <!-- Header/Navbar -->
  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">
      <a class="navbar-brand" href="/">Rohi Schools</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/about/">About</a></li>
          <li class="nav-item"><a class="nav-link" href="/portal.html">Portal</a></li>
          <li class="nav-item"><a class="nav-link" href="/contact/">Contact</a></li>
          <li class="nav-item"><a class="nav-link" href="/news/">News</a></li>
        </ul>
      </div>
    </div>
  </nav>

  {{ content | safe }}

  <!-- ======= Footer ======= -->
  <footer class="bg-dark text-white pt-5 pb-3 mt-5">
    <div class="container">
      <div class="row g-4">

        <!-- Logo and Tagline -->
        <div class="col-md-4">
          <img src="/img/rohilo.jpg" alt="Rohi Logo" width="40" class="mb-2 rounded">
          <h5 class="fw-bold mt-2">Rohi Schools</h5>
          <p>Raising principled leaders through sound education.</p>
        </div>

        <!-- Quick Links -->
        <div class="col-md-4">
          <h6 class="text-uppercase fw-bold mb-3">Quick Links</h6>
          <ul class="list-unstyled">
            <li><a href="/" class="footer-link">Home</a></li>
            <li><a href="/about/" class="footer-link">About</a></li>
            <li><a href="/about/#programAccordion" class="footer-link">Programs</a></li>
            <li><a href="/contact/" class="footer-link">Contact</a></li>
            <li><a href="/news/" class="footer-link">News</a></li>
          </ul>
        </div>

        <!-- Contact & Socials -->
        <div class="col-md-4">
          <h6 class="text-uppercase fw-bold mb-3">Contact Us</h6>
          <p><i class="bi bi-geo-alt-fill me-2 text-primary"></i>Adjacent Wise hotel New Range Ogun Radio,
            Abeokuta Ogun State.</p>
          <p><i class="bi bi-telephone-fill me-2"></i>+234 803 240 8415</p>
          <p><i class="bi bi-telephone-fill me-2"></i>+234 703 136 2416</p>
          <p><i class="bi bi-envelope-fill me-2"></i>rohicollegeogunradio@gmail.com</p>
          <div class="mt-3">
            <a href="https://www.facebook.com/profile.php?id=100063597926687" class="me-3 footer-icon"><i class="bi bi-facebook"></i></a>
            <a href="https://wa.me/2347031362416" target="_blank" class="me-3 footer-icon"><i class="bi bi-whatsapp"></i></a>
            <a href="#" class="me-3 footer-icon"><i class="bi bi-instagram"></i></a>
            <a href="#" class="footer-icon"><i class="bi bi-youtube"></i></a>
          </div>
        </div>

      </div>

      <hr class="border-top mt-4" />

      <div class="text-center small">
        <p class="mb-1">&copy; <span id="year"></span> Rohi Schools. All rights reserved.</p>
        <p class="" style="color: #ffffffc5;">🔧 Powered by <strong style="color: var(--rc-primary);">Brillytech Networks</strong></p>
      </div>
    </div>
  </footer>

  <!-- Scripts (only once) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <!-- AOS Animation Script -->
  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

  <script>
    AOS.init();
    const yearEl = document.getElementById("year");
    if (yearEl) yearEl.textContent = new Date().getFullYear();
  </script>

  <!-- ✅ NETLIFY IDENTITY WIDGET + FIX FOR FREE PLAN INVITE LINKS -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    // If Netlify sends invite/recovery tokens to "/" (free plan behavior),
    // forward them to "/admin/" where the Identity widget is handled.
    if (window.location.hash.includes("invite_token") ||
        window.location.hash.includes("recovery_token") ||
        window.location.hash.includes("confirmation_token")) {
      window.location.href = "/admin/" + window.location.hash;
    }
  </script>

</body>
</html>