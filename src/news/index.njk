---
layout: layouts/base.njk
title: News & Updates
permalink: /news/
---

<section class="py-5 news-page">
  <div class="container">
    <div class="text-center mb-5">
      <h1 class="fw-bold">News & Updates</h1>
      <p class="text-muted">Latest announcements, events, and milestones from Rohi Schools.</p>
    </div>

    {% if collections.posts and collections.posts.length > 0 %}
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for post in collections.posts %}
          <div class="col" data-aos="fade-up" data-aos-delay="{{ 100 * loop.index }}">
            <div class="card h-100 shadow-sm news-card border-0">
              {% if post.data.image %}
                <img src="{{ post.data.image }}" class="card-img-top news-img" alt="{{ post.data.title }}">
              {% endif %}

              <div class="card-body d-flex flex-column">
                <small class="news-date mb-2">{{ post.date | date("MMMM dd, yyyy") }}</small>
                <h5 class="card-title fw-bold">{{ post.data.title }}</h5>

                <p class="card-text text-muted flex-grow-1">
                  {{ post.data.excerpt or post.templateContent | striptags | truncate(140) }}
                </p>

                <a href="{{ post.url }}" class="btn btn-dark btn-sm mt-2 align-self-start rounded-pill px-3">
                  Read More
                </a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="alert alert-info text-center">
        No posts yet. We’ll publish updates soon.
      </div>
    {% endif %}
  </div>
</section>