---
layout: layouts/base.njk
title: News & Updates
permalink: /news/
---

<section class="py-5">
  <div class="container">
    <h1 class="fw-bold mb-4">News & Updates</h1>
    <p class="text-muted mb-4">Latest announcements, events, and milestones.</p>

    {% if collections.posts and collections.posts.length > 0 %}
      <div class="row g-4">
        {% for post in collections.posts | reverse %}
          <div class="col-md-4">
            <div class="card shadow-sm h-100">
              {% if post.data.image %}
                <img src="{{ post.data.image }}" class="card-img-top" alt="{{ post.data.title }}">
              {% endif %}
              <div class="card-body">
                <h5 class="card-title">{{ post.data.title }}</h5>
                <small class="text-muted">{{ post.date | date("MMMM dd, yyyy") }}</small>
                <p class="mt-2">{{ post.data.excerpt }}</p>
                <a href="{{ post.url }}" class="btn btn-sm btn-outline-primary mt-2">Read More</a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="alert alert-info">
        No posts yet. We’ll publish updates soon.
      </div>
    {% endif %}

  </div>
</section>