<!-- Hero -->
<section class="py-5 text-center bg-light" data-aos="zoom-in" data-aos-duration="1200">
  <div class="container">
    <h1 class="display-5 fw-bold mb-2 floating-contact">Contact Us</h1>
    <p class="text-muted lead" style="animation-delay: 1.5s;">We’d love to hear from you. Reach out anytime.</p>
  </div>
</section>

<!-- Contact Form Section -->
<section class="py-5" data-aos="fade-up">
  <div class="container">
    <div class="row g-5">

      <!-- Contact Form -->
      <div class="col-md-7">
        <div class="p-4 shadow rounded bg-white">

          <!-- NOTE: This is UI only for now (no backend). We will connect it later. -->
          <form name="contact" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="contact" />

            <div class="mb-3">
              <label class="form-label">Full Name</label>
              <input name="name" type="text" class="form-control" placeholder="Enter your name" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Email Address</label>
              <input name="email" type="email" class="form-control" placeholder="Enter your email" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Subject</label>
              <input name="subject" type="text" class="form-control" placeholder="Subject" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Message</label>
              <textarea name="message" class="form-control" rows="5" placeholder="Type your message here..." required></textarea>
            </div>

            <button type="submit" class="btn hero-btn">Send Message</button>
          </form>

        </div>
      </div>

      <!-- Contact Info -->
      <div class="col-md-5" data-aos="fade-left">
        <div class="p-4 bg-light rounded shadow-sm">
          <h5 class="fw-bold mb-3">Rohi Schools</h5>

          <p><i class="bi bi-geo-alt-fill me-2 text-primary"></i>Adjacent Wise hotel New Range Ogun Radio, Abeokuta Ogun State.</p>
          <p><i class="bi bi-telephone-fill me-2"></i>+234 803 240 8415</p>
          <p><i class="bi bi-telephone-fill me-2"></i>+234 703 136 2416</p>
          <p><i class="bi bi-envelope-fill me-2"></i>rohicollegeogunradio@gmail.com</p>

          <div class="mt-3">
            <a href="https://www.facebook.com/profile.php?id=100063597926687" class="me-3 footer-icon" aria-label="Facebook">
              <i class="bi bi-facebook"></i>
            </a>
            <a href="https://wa.me/2347031362416" target="_blank" class="me-3 footer-icon" aria-label="WhatsApp">
              <i class="bi bi-whatsapp"></i>
            </a>
            <a href="#" class="me-3 footer-icon" aria-label="Instagram">
              <i class="bi bi-instagram"></i>
            </a>
            <a href="#" class="footer-icon" aria-label="YouTube">
              <i class="bi bi-youtube"></i>
            </a>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>